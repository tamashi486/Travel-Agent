# LLM (OpenAI / DeepSeek etc.)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Amap API Key (passed to Amap MCP Server subprocess)
AMAP_API_KEY=your_amap_api_key_here

# Amap MCP Server path (optional, auto-detected by default)
# MCP_SERVER_PATH=/absolute/path/to/mcp-server/server.py