# ===========================
# LLM（兼容 OpenAI 接口格式）
# ===========================
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1     # SiliconFlow: https://api.siliconflow.cn/v1
LLM_MODEL_ID=gpt-4o                        # 推理模型示例: Pro/moonshotai/Kimi-K2-Thinking
LLM_TIMEOUT=300                            # 推理模型建议 1800

# ===========================
# 高德地图
# ===========================
AMAP_API_KEY=your_amap_api_key_here
# MCP_SERVER_PATH=/absolute/path/to/mcp-server/server.py  # 可选，留空则自动定位

# ===========================
# 服务器
# ===========================
HOST=0.0.0.0
PORT=8001

# ===========================
# CORS
# ===========================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================
# Redis 缓存（可选，留空则自动禁用）
# ===========================
REDIS_URL=redis://localhost:6379

# ===========================
# 限流（可选，默认每 IP 每分钟 10 次）
# ===========================
RATE_LIMIT_PER_MINUTE=10

# ===========================
# Unsplash 图片（可选）
# ===========================
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ===========================
# 日志
# ===========================
LOG_LEVEL=INFO
